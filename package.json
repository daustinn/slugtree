{
  "name": "slugtree",
  "version": "0.5.1",
  "description": "Write in MDX. Let Slugtree build the tree",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "react": [
        "./dist/react.d.ts"
      ],
      "next": [
        "./dist/next.d.ts"
      ]
    }
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    },
    "./next": {
      "types": "./dist/next.d.ts",
      "import": "./dist/next.js",
      "require": "./dist/next.js"
    }
  },
  "files": [
    "dist"
  ],
  "scripts": {
    "dev": "tsc --watch",
    "build": "node scripts/mock-generated.js && tsc",
    "test": "node scripts/mock-generated.js && vitest run",
    "lint": "eslint ."
  },
  "repository": {
    "type": "git",
    "url": "https://github.com/daustinn/slugtree.git"
  },
  "homepage": "https://slugtree.daustinn.com",
  "keywords": [
    "next.js",
    "docs",
    "mdx",
    "documentation",
    "builder",
    "generator"
  ],
  "author": "Daustinn",
  "license": "MIT",
  "peerDependencies": {
    "next": ">=16.0.0",
    "react": "19.0.0",
    "react-dom": "19.0.0"
  },
  "dependencies": {
    "chokidar": "5.0.0",
    "gray-matter": "4.0.3",
    "picocolors": "1.1.1"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/chai": "5.2.3",
    "@types/node": "20",
    "@types/react": "19",
    "eslint": "10.4.1",
    "next": ">=16.0.0",
    "react": ">=19.0.0",
    "react-dom": ">=19.0.0",
    "turbo": "2.9.16",
    "typescript": "5.9.2",
    "vitest": "2.0.0"
  },
  "packageManager": "pnpm@9.4.0"
}
