{
  "name": "slugtree",
  "version": "0.1.0",
  "description": "Write in MDX. Let Slugtree build the tree",
  "type": "module",
  "main": "./dist/index.js",
  "module": "./dist/index.js",
  "types": "./dist/index.d.ts",
  "typesVersions": {
    "*": {
      "react": [
        "./dist/react.d.ts"
      ],
      "next": [
        "./dist/next.d.ts"
      ]
    }
  },
  "exports": {
    ".": {
      "types": "./dist/index.d.ts",
      "import": "./dist/index.js"
    },
    "./react": {
      "types": "./dist/react.d.ts",
      "import": "./dist/react.js"
    },
    "./next": {
      "types": "./dist/next.d.ts",
      "import": "./dist/next.js",
      "require": "./dist/next.js"
    }
  },
  "files": [
    "dist/index.js",
    "dist/index.d.ts",
    "dist/react.js",
    "dist/react.d.ts",
    "dist/next.js",
    "dist/next.d.ts",
    "dist/plugin.js",
    "dist/plugin.d.ts",
    "dist/types.d.ts"
  ],
  "scripts": {
    "dev": "turbo run dev --filter=website //#dev:lib",
    "dev:website": "turbo run dev --filter=website",
    "dev:lib": "tsc --watch",
    "build": "turbo run build --filter=website //#build:lib",
    "build:website": "turbo run build --filter=website",
    "build:lib": "tsc",
    "test": "turbo run //#test:lib",
    "test:lib": "vitest run",
    "lint": "turbo run lint --filter=website //#lint:lib",
    "lint:website": "turbo run lint --filter=website",
    "lint:lib": "eslint ."
  },
  "workspaces": [
    ".",
    "website"
  ],
  "repository": {
    "type": "git",
    "url": "https://github.com/daustinn/slugtree.git"
  },
  "keywords": [
    "next.js",
    "docs",
    "mdx",
    "documentation",
    "builder",
    "generator"
  ],
  "author": "Daustinn",
  "license": "MIT",
  "peerDependencies": {
    "react": "^19.0.0",
    "react-dom": "^19.0.0",
    "next": ">=16.0.0"
  },
  "dependencies": {
    "chokidar": "5.0.0",
    "gray-matter": "4.0.3",
    "picocolors": "^1.1.1"
  },
  "devDependencies": {
    "@eslint/js": "10.0.1",
    "@types/chai": "5.2.3",
    "@types/node": "^20",
    "@types/react": "^19",
    "eslint": "10.4.1",
    "next": ">=16.0.0",
    "react": "^19.0.0",
    "turbo": "2.9.16",
    "typescript": "^5.9.2",
    "vitest": "^2.0.0"
  },
  "packageManager": "npm@10.8.1"
}
